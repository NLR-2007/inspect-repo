    {
      "line_number": 73,
      "content": "        return \"placeholder\""
    },
    {
      "line_number": 74,
      "content": ""
    },
    {
      "line_number": 75,
      "content": "    if \"process.env\" in lower_line or \"os.getenv\" in lower_line or \"env[\" in lower_line:"
    },
    {
