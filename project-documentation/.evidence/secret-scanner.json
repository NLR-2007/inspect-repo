    },
    {
      "line_number": 77,
      "content": ""
    },
    {
      "line_number": 78,
      "content": "    if \"/test/\" in lower_path or \"/tests/\" in lower_path or \"test_\" in lower_path or \"mock\" in lower_path:"
    },
    {
      "line_number": 79,
      "content": "        return \"test_credential\""
    },
    {
      "line_number": 80,
      "content": ""
    },
    {
      "line_number": 81,
      "content": "    entropy = calculate_shannon_entropy(match_str)"
    },
    {
      "line_number": 82,
      "content": "    if entropy > 3.2 and len(match_str) >= 16:"
    },
    {
      "line_number": 83,
      "content": "        return \"suspected_real_credential\""
    },
    {
      "line_number": 84,
      "content": ""
    },
