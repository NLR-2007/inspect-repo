      "content": "    for file_path in root.glob(\"**/*\"):"
    },
    {
      "line_number": 100,
      "content": "        if any(part in file_path.parts for part in [\"node_modules\", \".git\", \"venv\", \".venv\", \"dist\", \"build\"]):"
    },
    {
      "line_number": 101,
      "content": "            continue"
    },
    {
      "line_number": 102,
      "content": "        if file_path.is_file():"
    },
    {
      "line_number": 103,
      "content": "            # Skip large binary files"
