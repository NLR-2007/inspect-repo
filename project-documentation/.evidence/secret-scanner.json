    {
      "line_number": 56,
      "content": "def calculate_shannon_entropy(data: str) -> float:"
    },
    {
      "line_number": 57,
      "content": "    \"\"\"Calculate Shannon entropy to measure randomness.\"\"\""
    },
    {
      "line_number": 58,
      "content": "    if not data:"
    },
    {
      "line_number": 59,
      "content": "        return 0.0"
    },
    {
      "line_number": 60,
      "content": "    entropy = 0.0"
    },
    {
      "line_number": 61,
      "content": "    for x in set(data):"
    },
    {
      "line_number": 62,
      "content": "        p_x = float(data.count(x)) / len(data)"
    },
    {
      "line_number": 63,
      "content": "        entropy -= p_x * math.log(p_x, 2)"
    },
    {
      "line_number": 64,
      "content": "    return round(entropy, 2)"
    },
    {
      "line_number": 65,
      "content": ""
    },
    {
      "line_number": 66,
      "content": "def classify_secret_kind(match_str: str, file_path: str, line_content: str) -> str:"
    },
    {
      "line_number": 67,
      "content": "    \"\"\"Classify credential into placeholder, env ref, test credential, or suspected real.\"\"\""
