    {
      "line_number": 144,
      "content": "def scan_languages(root: Path) -> dict:"
    },
    {
      "line_number": 145,
      "content": "    \"\"\"Determine programming language usage by count and volume.\"\"\""
    },
    {
      "line_number": 146,
      "content": "    counts = {}"
    },
    {
      "line_number": 147,
      "content": "    total_files = 0"
    },
    {
      "line_number": 148,
      "content": "    for file_path in root.glob(\"**/*\"):"
    },
    {
      "line_number": 149,
      "content": "        if file_path.is_file() and not any(part in file_path.parts for part in [\"node_modules\", \".git\", \"venv\", \"dist\", \"build\"]):"
    },
    {
      "line_number": 150,
      "content": "            ext = file_path.suffix.lower()"
    },
    {
      "line_number": 151,
      "content": "            if ext in LANG_EXTENSIONS:"
    },
    {
      "line_number": 152,
      "content": "                lang = LANG_EXTENSIONS[ext]"
    },
    {
      "line_number": 153,
      "content": "                counts[lang] = counts.get(lang, 0) + 1"
    },
    {
      "line_number": 154,
      "content": "                total_files += 1"
    },
    {
      "line_number": 155,
      "content": ""
    },
    {
      "line_number": 156,
      "content": "    language_findings = []"
    },
    {
      "line_number": 157,
      "content": "    for lang, count in counts.items():"
    },
    {
      "line_number": 158,
      "content": "        percent = round((count / max(total_files, 1)) * 100, 1)"
    },
    {
      "line_number": 159,
      "content": "        language_findings.append({"
    },
    {
      "line_number": 160,
      "content": "            \"technology\": lang,"
    },
    {
      "line_number": 161,
      "content": "            \"category\": \"Programming languages\","
    },
    {
      "line_number": 162,
      "content": "            \"version\": \"Repo Standard\","
    },
    {
      "line_number": 163,
      "content": "            \"version_source\": \"Source Files\","
    },
    {
      "line_number": 164,
      "content": "            \"file_count\": count,"
    },
    {
      "line_number": 165,
      "content": "            \"percentage\": percent,"
    },
    {
      "line_number": 166,
      "content": "            \"confidence\": \"CONFIRMED\","
    },
    {
      "line_number": 167,
      "content": "            \"usage\": f\"Primary/Secondary language ({percent}%)\""
    },
