      "content": "        \"detected_technologies_count\": len(all_technologies),"
    },
    {
      "line_number": 201,
      "content": "        \"categories\": by_category,"
    },
    {
      "line_number": 202,
      "content": "        \"raw_evidence\": all_technologies"
