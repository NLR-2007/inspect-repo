    {
      "line_number": 171,
      "content": "def detect_technology_stack(root_dir: str) -> dict:"
    },
    {
      "line_number": 172,
      "content": "    \"\"\"Main technological stack detection function.\"\"\""
    },
    {
      "line_number": 173,
      "content": "    root = Path(root_dir).resolve()"
    },
    {
      "line_number": 174,
      "content": "    if not root.exists():"
    },
    {
      "line_number": 175,
      "content": "        raise ValueError(f\"Directory not found: {root_dir}\")"
    },
    {
      "line_number": 176,
      "content": ""
    },
    {
      "line_number": 177,
      "content": "    manifest_findings = scan_manifests(root)"
    },
    {
      "line_number": 178,
      "content": "    pattern_findings = scan_file_patterns(root)"
    },
    {
      "line_number": 179,
      "content": "    languages = scan_languages(root)"
    },
    {
      "line_number": 180,
      "content": ""
    },
    {
      "line_number": 181,
      "content": "    # Deduplicate findings by technology name"
    },
    {
      "line_number": 182,
      "content": "    combined = {}"
    },
    {
      "line_number": 183,
      "content": "    for item in manifest_findings + pattern_findings:"
    },
    {
      "line_number": 184,
      "content": "        tech = item[\"technology\"]"
    },
    {
      "line_number": 185,
      "content": "        if tech not in combined or item[\"confidence\"] == \"CONFIRMED\":"
    },
    {
      "line_number": 186,
      "content": "            combined[tech] = item"
    },
    {
      "line_number": 187,
      "content": ""
    },
    {
      "line_number": 188,
      "content": "    all_technologies = list(combined.values()) + languages"
    },
    {
      "line_number": 189,
      "content": ""
    },
    {
      "line_number": 190,
      "content": "    # Group by category"
    },
    {
      "line_number": 191,
      "content": "    by_category = {}"
    },
    {
      "line_number": 192,
      "content": "    for tech_item in all_technologies:"
    },
    {
      "line_number": 193,
      "content": "        cat = tech_item[\"category\"]"
    },
    {
      "line_number": 194,
      "content": "        if cat not in by_category:"
    },
    {
      "line_number": 195,
      "content": "            by_category[cat] = []"
    },
    {
      "line_number": 196,
      "content": "        by_category[cat].append(tech_item)"
    },
    {
      "line_number": 197,
      "content": ""
    },
    {
      "line_number": 198,
      "content": "    return {"
    },
    {
      "line_number": 199,
      "content": "        \"repository_root\": str(root),"
